> 	 Fast path: DF=0 with a real repeat -> page-sized chunks through
> 	 fast_rep_movs (calls c_sas_move_bytes_forward, which dispatches
> 	 RAM/ROM/VIDEO/LIM correctly). Any oddity (DF=1, 16-bit wrap,
> 	 anything the helper declines) drops to the per-byte slow loop.
>        */
>       if ( !GET_DF() && rep_count > 1 )
> 	 {
> 	 IBOOL use32 = (IBOOL)(GET_ADDRESS_SIZE() != USE16);
> 	 IU32 src_off = use32 ? GET_ESI() : GET_SI();
> 	 IU32 dst_off = use32 ? GET_EDI() : GET_DI();
> 	 ISM32 src_seg_idx = (segment_override == SEG_CLR)
> 				? DS_REG : segment_override;
> 	 while ( rep_count > 0 )
> 	    {
> 	    IU32 done = fast_rep_movs(src_seg_idx, src_off, dst_off,
> 				      rep_count, (IU32)1, use32);
> 	    if ( done == 0 ) break;
> 	    src_off += done;
> 	    dst_off += done;
> 	    rep_count -= done;
> 	    if ( use32 )
> 	       {
> 	       SET_ESI(src_off);
> 	       SET_EDI(dst_off);
> 	       if ( repeat != REP_CLR ) SET_ECX(rep_count);
> 	       }
> 	    else
> 	       {
> 	       SET_SI((IU16)src_off);
> 	       SET_DI((IU16)dst_off);
> 	       if ( repeat != REP_CLR ) SET_CX((IU16)rep_count);
> 	       if ( src_off >= 0x10000 || dst_off >= 0x10000 ) break;
> 	       }
> 	    }
> 	 }
